<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Talks to a user-supplied llama-server over the local network. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Keep the token stream alive (and visible, with a Cancel action) while the
         app is backgrounded, via a foreground service. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Chat attachments: photo capture, gallery access (full media access rather
         than the limited photo picker, by explicit user preference) and voice
         messages for vision/audio-capable models. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Gallery export writes into MediaStore, which is permissionless from
         API 29; only the legacy 26–28 path still needs this. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".LlamaChatApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LlamaChat"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.LlamaChat">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".data.gen.GenerationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".data.gen.SummarizationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".data.comfy.ComfyGenerationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".data.gen.SceneImageService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Hands the camera app a writable URI for photo capture. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="net.maz.llamachat.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
